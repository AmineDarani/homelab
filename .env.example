# =============================================================================
# HOMELAB GLOBAL ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file -- it contains secrets.
# =============================================================================


# =============================================================================
# GLOBAL SETTINGS
# =============================================================================
DOMAIN=mylab.com
ACME_EMAIL=admin@mylab.com
TZ=America/New_York
LINUX_VM_IP=<your-linux-vm-ip>


# =============================================================================
# ACTIVE DIRECTORY (Windows Domain Controller)
# =============================================================================
# Create a service account on the DC first (see README.md)
AD_DC_IP=<windows-dc-ip>
AD_BASE_DN=DC=mylab,DC=com
AD_BIND_DN=CN=svc_authentik,CN=Users,DC=mylab,DC=com
AD_BIND_PASSWORD=<change-me>


# =============================================================================
# AUTHENTIK (SSO / Identity Provider)
# =============================================================================
# Generate secret key with: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=<generate-a-long-random-string>
AUTHENTIK_POSTGRES_PASSWORD=<change-me>

# OIDC credentials -- leave blank until Authentik is set up in Phase 2,
# then create providers in the Authentik UI and paste the values here.
AUTHENTIK_OIDC_CLIENT_ID=
AUTHENTIK_OIDC_CLIENT_SECRET=


# =============================================================================
# GRAFANA
# =============================================================================
GRAFANA_ADMIN_PASSWORD=<change-me>


# =============================================================================
# WAZUH (SIEM / XDR)
# =============================================================================
WAZUH_INDEXER_PASSWORD=<change-me>
WAZUH_API_PASSWORD=<change-me>


# =============================================================================
# BOOKSTACK (Wiki)
# =============================================================================
BOOKSTACK_DB_PASSWORD=<change-me>


# =============================================================================
# WIREGUARD (VPN)
# =============================================================================
# The IP or hostname that VPN clients will connect to
WG_HOST=<linux-vm-public-or-lan-ip>
# Generate with: docker run -it ghcr.io/wg-easy/wg-easy wgpw 'YOUR_PASSWORD'
WG_PASSWORD_HASH=<generate-bcrypt-hash>
